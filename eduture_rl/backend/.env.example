SECRET_KEY=replace-with-a-long-random-secret
# Local SQLite option:
# DATABASE_URL=sqlite:///./eduture.db

# Docker Compose backend service uses Postgres on the internal `db` host.
# If you use the root compose file, the frontend will call the backend at http://localhost:8000.

# PostgreSQL option (recommended):
POSTGRES_DB=eduture
POSTGRES_USER=eduture
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql+psycopg://eduture:replace-with-a-strong-password@localhost:5432/eduture

CORS_ORIGINS=["http://localhost:5173"]
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
TRUSTED_HOSTS=["localhost","127.0.0.1","*.vercel.app"]
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/5minute
RATE_LIMIT_GENERAL=100/minute
AUDIT_LOG_ENABLED=true
LOG_LEVEL=INFO
# Google OAuth 2.0 (optional)
# GOOGLE_OAUTH_ENABLED=true
# GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
# GOOGLE_OAUTH_REDIRECT_URI=https://your-project.vercel.app/api/auth/google/callback
# GOOGLE_OAUTH_FRONTEND_SUCCESS_URL=https://your-project.vercel.app/login?oauth=success
# GOOGLE_OAUTH_FRONTEND_ERROR_URL=https://your-project.vercel.app/login?oauth=error
# Optional explicit admin bootstrap. Leave disabled unless you need to create the first admin.
# ADMIN_BOOTSTRAP_ENABLED=false
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-password
# ADMIN_BOOTSTRAP_FULL_NAME=EDUTURE Admin
